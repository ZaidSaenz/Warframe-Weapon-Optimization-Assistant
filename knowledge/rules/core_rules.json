{
  "rules": [
    {
      "id": "retrieve_primary_job_selection",
      "always": true,
      "retrieve": [
        "primary_job_selection"
      ]
    },
    {
      "id": "retrieve_improvement_selection",
      "always": true,
      "retrieve": [
        "improvement_selection"
      ]
    },
    {
      "id": "retrieve_critical_profile",
      "match": "any",
      "conditions": [
        {
          "field": "critical_relationship",
          "operator": "in",
          "value": [
            "limited",
            "moderate",
            "aligned",
            "mixed"
          ]
        }
      ],
      "retrieve": [
        "critical_profile"
      ]
    },
    {
      "id": "retrieve_status_application",
      "match": "any",
      "conditions": [
        {
          "field": "status_relationship",
          "operator": "in",
          "value": [
            "limited",
            "moderate",
            "aligned",
            "mixed"
          ]
        }
      ],
      "retrieve": [
        "status_application"
      ]
    },
    {
      "id": "retrieve_attack_rhythm",
      "match": "any",
      "conditions": [
        {
          "field": "attack_behavior",
          "operator": "in",
          "value": [
            "automatic",
            "semi_automatic",
            "burst",
            "charge",
            "continuous",
            "active",
            "duplex",
            "melee_repeated"
          ]
        }
      ],
      "retrieve": [
        "attack_rhythm"
      ]
    },
    {
      "id": "retrieve_damage_delivery",
      "match": "any",
      "conditions": [
        {
          "field": "damage_delivery",
          "operator": "in",
          "value": [
            "direct",
            "projectile",
            "radial",
            "mixed",
            "beam"
          ]
        }
      ],
      "retrieve": [
        "damage_delivery"
      ]
    },
    {
      "id": "retrieve_multi_mode_behavior",
      "match": "all",
      "conditions": [
        {
          "field": "attack_mode_count",
          "operator": "greater_than",
          "value": 1
        }
      ],
      "retrieve": [
        "multi_mode_behavior"
      ]
    },
    {
      "id": "retrieve_multi_instance_delivery",
      "match": "all",
      "conditions": [
        {
          "field": "has_multi_instance_evidence",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "multi_instance_delivery"
      ]
    },
    {
      "id": "retrieve_melee_behavior",
      "match": "any",
      "conditions": [
        {
          "field": "weapon_category",
          "operator": "in",
          "value": [
            "melee",
            "archmelee",
            "drifter_melee"
          ]
        }
      ],
      "retrieve": [
        "melee_behavior"
      ]
    },
    {
      "id": "retrieve_description_evidence",
      "match": "all",
      "conditions": [
        {
          "field": "description_mechanic_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "description_evidence"
      ]
    },
    {
      "id": "retrieve_reload_friction",
      "match": "any",
      "conditions": [
        {
          "field": "reload_friction",
          "operator": "in",
          "value": [
            "moderate",
            "high",
            "special_reload"
          ]
        }
      ],
      "retrieve": [
        "reload_friction"
      ]
    },
    {
      "id": "retrieve_sustained_behavior",
      "match": "all",
      "conditions": [
        {
          "field": "damage_behavior",
          "operator": "equals",
          "value": "sustained"
        }
      ],
      "retrieve": [
        "sustained_damage"
      ]
    },
    {
      "id": "retrieve_beam_behavior",
      "match": "all",
      "conditions": [
        {
          "field": "damage_delivery",
          "operator": "equals",
          "value": "beam"
        }
      ],
      "retrieve": [
        "beam_behavior"
      ]
    },
    {
      "id": "retrieve_structured_multi_target",
      "match": "all",
      "conditions": [
        {
          "field": "has_structured_multi_target_evidence",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "multi_target_delivery"
      ]
    },
    {
      "id": "retrieve_descriptive_multi_target",
      "match": "all",
      "conditions": [
        {
          "field": "multi_target_evidence_quality",
          "operator": "equals",
          "value": "descriptive"
        }
      ],
      "retrieve": [
        "multi_target_delivery"
      ]
    },
    {
      "id": "retrieve_special_mechanic_review",
      "match": "all",
      "conditions": [
        {
          "field": "special_mechanic_needs_review",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "special_mechanic_review"
      ]
    },
    {
      "id": "retrieve_ammo_consumption_rate",
      "match": "any",
      "conditions": [
        {
          "field": "consumption_rate_signal",
          "operator": "in",
          "value": [
            "moderate",
            "elevated"
          ]
        }
      ],
      "retrieve": [
        "ammo_consumption"
      ]
    },
    {
      "id": "retrieve_ammo_economy",
      "match": "any",
      "conditions": [
        {
          "field": "ammo_economy_signal",
          "operator": "in",
          "value": [
            "moderate",
            "elevated"
          ]
        }
      ],
      "retrieve": [
        "ammo_consumption"
      ]
    },
    {
      "id": "retrieve_operational_comfort",
      "match": "any",
      "conditions": [
        {
          "field": "reload_friction",
          "operator": "in",
          "value": [
            "moderate",
            "high",
            "special_reload"
          ]
        },
        {
          "field": "handling_friction",
          "operator": "in",
          "value": [
            "moderate",
            "high"
          ]
        },
        {
          "field": "has_charge_evidence",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "operational_comfort"
      ]
    }
  ]
}