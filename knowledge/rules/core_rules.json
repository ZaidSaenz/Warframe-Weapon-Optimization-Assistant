{
  "rules": [
    {
      "id": "retrieve_primary_job_selection",
      "always": true,
      "retrieve": [
        "primary_job_selection"
      ]
    },
    {
      "id": "retrieve_improvement_selection",
      "always": true,
      "retrieve": [
        "improvement_selection"
      ]
    },
    {
      "id": "retrieve_critical_profile",
      "match": "any",
      "conditions": [
        {
          "field": "critical_profile_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "critical_chance",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "critical_multiplier",
          "operator": "greater_than",
          "value": 0
        }
      ],
      "retrieve": [
        "critical_profile"
      ]
    },
    {
      "id": "retrieve_status_application",
      "match": "any",
      "conditions": [
        {
          "field": "status_profile_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "status_chance",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "eligible_status_opportunity_profile_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "status_application"
      ]
    },
    {
      "id": "retrieve_attack_rhythm",
      "match": "any",
      "conditions": [
        {
          "field": "trigger_type",
          "operator": "in",
          "value": [
            "automatic",
            "semi_automatic",
            "burst",
            "charge",
            "duplex",
            "held",
            "staged",
            "secondary_activation",
            "melee"
          ]
        },
        {
          "field": "burst_count",
          "operator": "greater_than",
          "value": 1
        },
        {
          "field": "charge_time",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "has_spool_up_evidence",
          "operator": "equals",
          "value": true
        },
        {
          "field": "has_press_release_evidence",
          "operator": "equals",
          "value": true
        },
        {
          "field": "has_secondary_activation_evidence",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "attack_rhythm"
      ]
    },
    {
      "id": "retrieve_damage_delivery",
      "match": "any",
      "conditions": [
        {
          "field": "delivery_path",
          "operator": "in",
          "value": [
            "hitscan",
            "projectile",
            "beam",
            "undetermined"
          ]
        },
        {
          "field": "spatial_application",
          "operator": "in",
          "value": [
            "direct",
            "radial",
            "mixed",
            "undetermined"
          ]
        },
        {
          "field": "damage_components_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "damage_delivery"
      ]
    },
    {
      "id": "retrieve_multi_mode_behavior",
      "match": "any",
      "conditions": [
        {
          "field": "attack_mode_records_count",
          "operator": "greater_than",
          "value": 1
        },
        {
          "field": "has_mode_state_evidence",
          "operator": "equals",
          "value": true
        },
        {
          "field": "has_parent_mode_relationship",
          "operator": "equals",
          "value": true
        },
        {
          "field": "has_ambiguous_mode_records",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "multi_mode_behavior"
      ]
    },
    {
      "id": "retrieve_multi_instance_delivery",
      "match": "any",
      "conditions": [
        {
          "field": "base_instance_count",
          "operator": "greater_than",
          "value": 1
        },
        {
          "field": "pellet_count",
          "operator": "greater_than",
          "value": 1
        },
        {
          "field": "multishot",
          "operator": "greater_than",
          "value": 1
        },
        {
          "field": "damage_component_count",
          "operator": "greater_than",
          "value": 1
        },
        {
          "field": "has_conditional_instance_evidence",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "multi_instance_delivery"
      ]
    },
    {
      "id": "retrieve_melee_behavior",
      "match": "any",
      "conditions": [
        {
          "field": "weapon_category",
          "operator": "in",
          "value": [
            "melee",
            "archmelee",
            "drifter_melee"
          ]
        },
        {
          "field": "melee_attack_records_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "melee_behavior"
      ]
    },
    {
      "id": "retrieve_description_evidence",
      "match": "any",
      "conditions": [
        {
          "field": "description_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "description_claims_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "description_evidence"
      ]
    },
    {
      "id": "retrieve_reload_friction",
      "match": "any",
      "conditions": [
        {
          "field": "recovery_model",
          "operator": "in",
          "value": [
            "full_magazine",
            "incremental",
            "regenerative",
            "staged"
          ]
        },
        {
          "field": "reload_time",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "reload_delay",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "reload_rate",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "reload_unit_time",
          "operator": "greater_than",
          "value": 0
        }
      ],
      "retrieve": [
        "reload_friction"
      ]
    },
    {
      "id": "retrieve_sustained_damage",
      "match": "any",
      "conditions": [
        {
          "field": "sustained_cycle_profile_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "has_repeatable_attack_cycle",
          "operator": "equals",
          "value": true
        },
        {
          "field": "active_damage_output_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "mechanical_application_continuity_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "sustained_damage"
      ]
    },
    {
      "id": "retrieve_beam_behavior",
      "match": "any",
      "conditions": [
        {
          "field": "uses_beam_delivery",
          "operator": "equals",
          "value": true
        },
        {
          "field": "delivery_path",
          "operator": "equals",
          "value": "beam"
        }
      ],
      "retrieve": [
        "beam_behavior"
      ]
    },
    {
      "id": "retrieve_multi_target_delivery",
      "match": "any",
      "conditions": [
        {
          "field": "multi_target_mechanic_records_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "has_radial_component",
          "operator": "equals",
          "value": true
        },
        {
          "field": "has_chaining",
          "operator": "equals",
          "value": true
        },
        {
          "field": "punch_through_depth",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "distributed_instance_profile_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "multi_target_delivery"
      ]
    },
    {
      "id": "retrieve_special_mechanic_review",
      "match": "any",
      "conditions": [
        {
          "field": "special_mechanic_records_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "structured_special_mechanic_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "validated_description_mechanic_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "special_mechanic_review"
      ]
    },
    {
      "id": "retrieve_ammo_consumption",
      "match": "any",
      "conditions": [
        {
          "field": "ammo_reserve_model",
          "operator": "in",
          "value": [
            "finite",
            "regenerative",
            "shared",
            "unlimited"
          ]
        },
        {
          "field": "ammo_reserve_capacity",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "ammo_cost_per_consumption_event",
          "operator": "greater_than",
          "value": 0
        },
        {
          "field": "consumption_event_frequency_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "ammo_regeneration_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "ammo_consumption"
      ]
    },
    {
      "id": "retrieve_operational_comfort",
      "match": "any",
      "conditions": [
        {
          "field": "operational_friction_records_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "handling_friction_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "preparation_friction_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "interruption_friction_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "positioning_friction_present",
          "operator": "equals",
          "value": true
        },
        {
          "field": "tracking_friction_present",
          "operator": "equals",
          "value": true
        }
      ],
      "retrieve": [
        "operational_comfort"
      ]
    }
  ]
}